<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.shape.Rectangle?>

<StackPane fx:id="rootPane"
           stylesheets="@../css/common.css,@../css/game.css"
           styleClass="game-root"
           xmlns="http://javafx.com/javafx/8"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.space_invaders_online.game.sceneController.controllers.GameScreenController">

    <!-- Игровой Canvas -->
    <Canvas fx:id="gameCanvas"
            width="1280"
            height="720"
            styleClass="game-canvas"/>

    <!-- Кнопки управления [PAUSE / RESUME] -->
    <HBox fx:id="gameControlButtons" styleClass="control-button-container">
        <Button fx:id="resumeButton" styleClass="control-button" id="resume-button" />
        <Button fx:id="pauseButton"  styleClass="control-button" id="pause-button"  />
    </HBox>

    <!-- Оверлей паузы (изначально скрыт) -->
    <VBox fx:id="pauseOverlay" styleClass="pause-overlay">

        <Label text="PAUSED"
               styleClass="pause-title"/>

        <Label text="Press ESC to resume"
               styleClass="pause-hint"/>

        <Button fx:id="exitToMenuBtn"
                text="EXIT TO MENU"
                styleClass="exit-menu-button"/>

    </VBox>

</StackPane>
